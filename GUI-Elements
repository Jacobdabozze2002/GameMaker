function ProgressBar() : GUI_BaseClass() constructor
{
	background = new Rectangle();
	
	progressBar = new Rectangle();
	progressBar.setBothColorBackground(make_color_rgb(0,200,0));
	progressBar.setBothAlphaBorder(0);
		
	progressBarPosition = fa_left;
	
	scale_progress = .5;
	
	label = new Label();
	label.text = "0/0";
	
	borderLayer = new Rectangle();
	
	function draw()
	{
		var gui_width = window_get_width();
		var gui_height = window_get_height();
		display_set_gui_maximise(scale_width, scale_height, gui_width *scale_x, gui_height *scale_y);
				
		background.parent = self;
		background.setCenter(1,1);
		background.draw();
		
		if (scale_progress > 1)
			scale_progress = 1;
		if (scale_progress < 0)
			scale_progress = 0;
		
		progressBar.parent = self;
		progressBar.setLeftSideCenter(scale_progress,1);
		
		if (progressBarPosition == fa_center)
			progressBar.setCenter(scale_progress,1);
		if (progressBarPosition == fa_right)
			progressBar.setRightSideCenter(scale_progress,1);
		
		progressBar.draw();
		
		label.parent = self;
		label.setCenter(1,1);
		label.text_angle = 0;
		label.draw();
		
		borderLayer.parent = self;
		borderLayer.setCenter(1,1);
		borderLayer.alpha_Background = 0;
		borderLayer.alpha_Background_highlighted = 0;
		borderLayer.draw();
	}
	
	function setAll_Scale_Insets(_scale)
	{
		background.scale_insets = _scale;
		progressBar.scale_insets = _scale;
		borderLayer.scale_insets = _scale;
	}
	
	function setAllAlpha(_alpha = 1)
	{
		background.alpha_Border = _alpha;
		background.alpha_Background = _alpha;
		progressBar.alpha_Border = _alpha;
		progressBar.alpha_Background = _alpha;
		borderLayer.alpha_Border = _alpha;
		borderLayer.alpha_Background = _alpha;
		label.alpha = _alpha;
	}
	
	function setAllAlphaHighlighted(_alpha = 1)
	{
		background.alpha_Border_highlighted = _alpha;
		background.alpha_Background_highlighted = _alpha;
		progressBar.alpha_Border_highlighted = _alpha;
		progressBar.alpha_Background_highlighted = _alpha;
		borderLayer.alpha_Border_highlighted = _alpha;
		borderLayer.alpha_Background_highlighted = _alpha;
		label.alpha_highlighted = _alpha;
	}
	
	function setAllAlphaHighlighted_and_notHighlighted(_alpha = 1)
	{
		progressBar.alpha_Border = _alpha;
		progressBar.alpha_Background = _alpha;
		progressBar.alpha_Border_highlighted = _alpha;
		progressBar.alpha_Background_highlighted = _alpha;
		
		background.alpha_Border = _alpha;
		background.alpha_Background = _alpha;
		background.alpha_Border_highlighted = _alpha;
		background.alpha_Background_highlighted = _alpha;
		
		borderLayer.alpha_Border = _alpha;
		borderLayer.alpha_Background = _alpha;
		borderLayer.alpha_Border_highlighted = _alpha;
		borderLayer.alpha_Background_highlighted = _alpha;
		
		label.alpha = _alpha;
		label.alpha_highlighted = _alpha;
	}
}

function ProgressBar_Vertical() : ProgressBar() constructor
{
	progressBarPosition = fa_bottom;
	label.text_angle = 90;
	
	function draw()
	{
		var gui_width = window_get_width();
		var gui_height = window_get_height();
		display_set_gui_maximise(scale_width, scale_height, gui_width *scale_x, gui_height *scale_y);
				
		background.parent = self;
		background.setCenter(1,1);
		background.draw();
		
		if (scale_progress > 1)
			scale_progress = 1;
		if (scale_progress < 0)
			scale_progress = 0;
		
		progressBar.parent = self;
		progressBar.setBottomCenter(1,scale_progress);
		
		if (progressBarPosition == fa_middle)
			progressBar.setCenter(1,scale_progress);
		if (progressBarPosition == fa_top)
			progressBar.setTopCenter(1,scale_progress);
		
		progressBar.draw();
		
		label.parent = self;
		label.setCenter(1,1);
		
		if !(label.text_angle == 90 || label.text_angle == 270 || label.text_angle == 0)
			label.text_angle = 90;
		
		if (label.text_angle != 0)
			setAlignment();	
		
		label.draw();
		
		borderLayer.parent = self;
		borderLayer.setCenter(1,1);
		borderLayer.alpha_Background = 0;
		borderLayer.alpha_Background_highlighted = 0;
		borderLayer.draw();
	}
	
	var function setAlignment()
	{
		
		if (label.text_angle == 90)
		{	
			if (label.horizontal_alignment == fa_center)
			{				
				if (label.vertical_alignment == fa_top)
				{
					label.horizontal_alignment = fa_right;
					label.vertical_alignment = fa_middle;
					label.setTopCenter(0, 0);
					return;
				}
			
				if (label.vertical_alignment == fa_bottom)
				{
					label.horizontal_alignment = fa_left;
					label.vertical_alignment = fa_center;
					label.setBottomCenter(0, 0);
					return;
				}
			}	
			
			if (label.horizontal_alignment == fa_left)
			{				
				if (label.vertical_alignment == fa_middle)
				{
					label.horizontal_alignment = fa_center;
					label.vertical_alignment = fa_top;
					label.setBottomLeft(0, .5);
					return;
				}
				
				if (label.vertical_alignment == fa_top)
				{
					label.horizontal_alignment = fa_right;
					label.vertical_alignment = fa_left;
					label.setTopLeft(0, 0);
					return;
				}

				if (label.vertical_alignment == fa_bottom)
				{
					label.horizontal_alignment = fa_left;
					label.vertical_alignment = fa_left;
					label.setBottomLeft(0, 0);
					return;
				}
			}	
			
			if (label.horizontal_alignment == fa_right)
			{				
				if (label.vertical_alignment == fa_middle)
				{
					label.horizontal_alignment = fa_center;
					label.vertical_alignment = fa_top;
					label.setBottomRight(.5, .5);
					return;
				}
				
				if (label.vertical_alignment == fa_top)
				{
					label.horizontal_alignment = fa_right;
					label.vertical_alignment = fa_bottom;
					label.setTopRight(1,0);
					return;
				}

				if (label.vertical_alignment == fa_bottom)
				{
					label.horizontal_alignment = fa_top;
					label.vertical_alignment = fa_right;
					label.setBottomRight(0, 0);
					return;
				}
			}	
		}
		
		if (label.text_angle == 270)
		{	
			if (label.horizontal_alignment == fa_center)
			{				
				if (label.vertical_alignment == fa_top)
				{
					label.horizontal_alignment = fa_left;
					label.vertical_alignment = fa_middle;
					label.setTopCenter(0, 0);
					return;
				}
			
				if (label.vertical_alignment == fa_bottom)
				{
					label.horizontal_alignment = fa_right;
					label.vertical_alignment = fa_center;
					label.setBottomCenter(0, 0);
					return;
				}
			}	
			
			if (label.horizontal_alignment == fa_left)
			{				
				if (label.vertical_alignment == fa_middle)
				{
					label.horizontal_alignment = fa_center;
					label.vertical_alignment = fa_bottom;
					label.setLeftSideCenter(0, 0);
					return;
				}
				
				if (label.vertical_alignment == fa_top)
				{
					label.horizontal_alignment = fa_left;
					label.vertical_alignment = fa_right;
					label.setTopLeft(0, 0);
					return;
				}

				if (label.vertical_alignment == fa_bottom)
				{
					label.horizontal_alignment = fa_right;
					label.vertical_alignment = fa_right;
					label.setBottomLeft(0, 0);
					return;
				}
			}	
			
			if (label.horizontal_alignment == fa_right)
			{				
				if (label.vertical_alignment == fa_middle)
				{
					label.horizontal_alignment = fa_center;
					label.vertical_alignment = fa_top;
					label.setRightSideCenter(0, 0);
					return;
				}
				
				if (label.vertical_alignment == fa_top)
				{
					label.horizontal_alignment = fa_left;
					label.vertical_alignment = fa_top;
					label.setTopRight(0,0);
					return;
				}

				if (label.vertical_alignment == fa_bottom)
				{
					label.horizontal_alignment = fa_bottom;
					label.vertical_alignment = fa_left;
					label.setBottomRight(0, 0);
					return;
				}
			}	
		}
	}
}

