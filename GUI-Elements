		borderLayer.setBothAlphaBackground(0);
		borderLayer.draw();
	}

	var function setSpritePosition()
	{
		if (sprite_horizontal_alignment == fa_left && sprite_vertical_alignment == fa_top)
			sprite.setTopLeft(sprite_scale_width, sprite_scale_height);
			
		if (sprite_horizontal_alignment == fa_left && sprite_vertical_alignment == fa_middle)
			sprite.setLeftSideCenter(sprite_scale_width, sprite_scale_height);
			
		if (sprite_horizontal_alignment == fa_left && sprite_vertical_alignment == fa_bottom)
			sprite.setBottomLeft(sprite_scale_width, sprite_scale_height);			
			
		if (sprite_horizontal_alignment == fa_center && sprite_vertical_alignment == fa_top)
			sprite.setTopCenter(sprite_scale_width, sprite_scale_height);
			
		if (sprite_horizontal_alignment == fa_center && sprite_vertical_alignment == fa_middle)
			sprite.setCenter(sprite_scale_width, sprite_scale_height);
			
		if (sprite_horizontal_alignment == fa_center && sprite_vertical_alignment == fa_bottom)
			sprite.setBottomCenter(sprite_scale_width, sprite_scale_height);
			
		if (sprite_horizontal_alignment == fa_right && sprite_vertical_alignment == fa_top)
			sprite.setTopRight(sprite_scale_width, sprite_scale_height);
			
		if (sprite_horizontal_alignment == fa_right && sprite_vertical_alignment == fa_middle)
			sprite.setRightSideCenter(sprite_scale_width, sprite_scale_height);
			
		if (sprite_horizontal_alignment == fa_right && sprite_vertical_alignment == fa_bottom)
			sprite.setBottomRight(sprite_scale_width, sprite_scale_height);
	}

	function setAll_Scale_Insets(_scale)
	{
		background.scale_insets = _scale;
