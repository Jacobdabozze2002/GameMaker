function GUI_BaseClass() constructor
{
	scale_width = .5;
	scale_height = .5;
	scale_x = .25;
	scale_y = .25;
	
	parent = undefined;	
	isRectangularShape = true;
		
	alpha = 1;
	alpha_highlighted = 1;
	
	function mouseOver()
	{
		var gui_width = window_get_width();
		var gui_height = window_get_height();
		var _mouse_x = window_mouse_get_x();
		var _mouse_y = window_mouse_get_y();
		var _width = gui_width *scale_width;
		var _height = gui_height *scale_height;
		var _x = gui_width *scale_x;
		var _y = gui_height *scale_y;
		
		if (isRectangularShape)
			return point_in_rectangle(_mouse_x, _mouse_y, _x, _y, _x + _width, _y + _height);
		else
		{	
			var _h = _x + _width /2;
			var _k = _y + _height /2;
			
			return ((_mouse_x - _h)*(_mouse_x - _h)) / (_width/2*_width/2) + ((_mouse_y - _k)*(_mouse_y - _k)) / (_height/2*_height/2) <= 1;
		}
		
	}
			
	function setCenter(_scale_width = scale_width, _scale_height = scale_height) 
	{
		scale_width = is_undefined(parent) ? _scale_width : parent.scale_width * _scale_width;
		scale_height = is_undefined(parent) ? _scale_height : parent.scale_height * _scale_height;
		scale_x = is_undefined(parent) ? (1 - scale_width) / 2 : parent.scale_x + parent.scale_width / 2 - scale_width / 2;
		scale_y = is_undefined(parent) ? (1 - scale_height) / 2 : parent.scale_y + parent.scale_height / 2 - scale_height / 2;
	}
	
	function setTopLeft(_scale_width = scale_width, _scale_height = scale_height) 
	{
		scale_width = is_undefined(parent) ? _scale_width : parent.scale_width * _scale_width;
		scale_height = is_undefined(parent) ? _scale_height : parent.scale_height * _scale_height;
		scale_x = is_undefined(parent) ? 0 : parent.scale_x;
		scale_y = is_undefined(parent) ? 0 : parent.scale_y;
	}
	
	function setTopRight(_scale_width = scale_width, _scale_height = scale_height) 
	{
		scale_width = is_undefined(parent) ? _scale_width : parent.scale_width * _scale_width;
		scale_height = is_undefined(parent) ? _scale_height : parent.scale_height * _scale_height;
		scale_x = is_undefined(parent) ? 1 - scale_width : parent.scale_x + parent.scale_width - scale_width;
		scale_y = is_undefined(parent) ? 0 : parent.scale_y;
	}
	
	function setBottomLeft(_scale_width = scale_width, _scale_height = scale_height) 
	{
		scale_width = is_undefined(parent) ? _scale_width : parent.scale_width * _scale_width;
		scale_height = is_undefined(parent) ? _scale_height : parent.scale_height * _scale_height;
		scale_x = is_undefined(parent) ? 0 : parent.scale_x;
		scale_y = is_undefined(parent) ? 1 - scale_height : parent.scale_y + parent.scale_height - scale_height;
	}
	
	function setBottomRight(_scale_width = scale_width, _scale_height = scale_height) 
	{
		scale_width = is_undefined(parent) ? _scale_width : parent.scale_width * _scale_width;
		scale_height = is_undefined(parent) ? _scale_height : parent.scale_height * _scale_height;
		scale_x = is_undefined(parent) ? 1 - scale_width : parent.scale_x + parent.scale_width - scale_width;
		scale_y = is_undefined(parent) ? 1 - scale_height : parent.scale_y + parent.scale_height - scale_height;
	}
	
	function setTopCenter(_scale_width = scale_width, _scale_height = scale_height) 
	{
		scale_width = is_undefined(parent) ? _scale_width : parent.scale_width * _scale_width;
		scale_height = is_undefined(parent) ? _scale_height : parent.scale_height * _scale_height;
		scale_x = is_undefined(parent) ? (1 - scale_width) / 2 : parent.scale_x + parent.scale_width / 2 - scale_width / 2;
		scale_y = is_undefined(parent) ? 0 : parent.scale_y;
	}
	
	function setBottomCenter(_scale_width = scale_width, _scale_height = scale_height) 
	{
		scale_width = is_undefined(parent) ? _scale_width : parent.scale_width * _scale_width;
		scale_height = is_undefined(parent) ? _scale_height : parent.scale_height * _scale_height;
		scale_x = is_undefined(parent) ? (1 - scale_width) / 2 : parent.scale_x + parent.scale_width / 2 - scale_width / 2;
		scale_y = is_undefined(parent) ? 1 - scale_height : parent.scale_y + parent.scale_height - scale_height;
	}
	
	function setLeftSideCenter(_scale_width = scale_width, _scale_height = scale_height) 
	{
		scale_width = is_undefined(parent) ? _scale_width : parent.scale_width * _scale_width;
		scale_height = is_undefined(parent) ? _scale_height : parent.scale_height * _scale_height;
		scale_x = is_undefined(parent) ? 0 : parent.scale_x;
		scale_y = is_undefined(parent) ? (1 - scale_height) / 2 : parent.scale_y + parent.scale_height / 2 - scale_height / 2;
	}
	
	function setRightSideCenter(_scale_width = scale_width, _scale_height = scale_height) 
	{
		scale_width = is_undefined(parent) ? _scale_width : parent.scale_width * _scale_width;
		scale_height = is_undefined(parent) ? _scale_height : parent.scale_height * _scale_height;
		scale_x = is_undefined(parent) ?  1 - scale_width : parent.scale_x + parent.scale_width - scale_width;
		scale_y = is_undefined(parent) ? (1 - scale_height) / 2 : parent.scale_y + parent.scale_height / 2 - scale_height / 2;
	}
	
	function move(_scale_x = 0, _scale_y = 0)
	{
		scale_x += _scale_x;
		scale_y += _scale_y;
	}
}	

function Interactives() : GUI_BaseClass() constructor
{
	scale_border = .001;
		
	color_Border = make_color_rgb(255,255,255);
	color_Border_Highlighted = make_color_rgb(255,255,255);
	
	color_Background = make_color_rgb(0,0,0);
	color_Background_Highlighted = make_color_rgb(0,0,0);
	
	function setBothColorBorder(_color = make_color_rgb(0,0,0))
	{
		color_Border = _color;
		color_Border_Highlighted = _color;
	}
		
	function setBothColorBackground(_color = make_color_rgb(0,0,0))
	{
		color_Background = _color;
		color_Background_Highlighted = _color;
	}
		
	function setBothAlpha(_alpha = 1)
	{
		alpha = _alpha;
		alpha_highlighted = _alpha;
	}
			
	var function getBorderFactor()
	{
		return (window_get_width() < window_get_height() ? window_get_width() : window_get_height()) * scale_border / 2;
	}
}

function Rectangle() : Interactives() constructor
{
	insets = 0;
	
	function draw()
	{
		var gui_width = window_get_width();
		var gui_height = window_get_height();
		display_set_gui_maximise(scale_width, scale_height, gui_width *scale_x, gui_height *scale_y);
								
		var isHighlighted = mouseOver();
		draw_set_alpha(!isHighlighted ? alpha : alpha_highlighted);	
				
		draw_set_color(!isHighlighted ? color_Background : color_Background_Highlighted);
		draw_roundrect_ext(0,0, gui_width, gui_height, insets, insets, false);
		
		for (var i = 0; i <= getBorderFactor(); i++)
		{
			draw_set_color(!isHighlighted ? color_Border : color_Border_Highlighted);
			draw_roundrect_ext(i, i, gui_width - i, gui_height - i, insets, insets, true);
		}
	}
}

function Ellipse() : Interactives() constructor
{
	isRectangularShape = false;
	
	function draw()
	{
		var gui_width = window_get_width();
		var gui_height = window_get_height();
		display_set_gui_maximise(scale_width, scale_height, gui_width *scale_x, gui_height *scale_y);
								
		var isHighlighted = mouseOver();
		draw_set_alpha(!isHighlighted ? alpha : alpha_highlighted);						
								
		draw_set_color(!isHighlighted ? color_Background : color_Background_Highlighted);
		draw_ellipse(0,0, gui_width, gui_height, false);
				
		for (var i = 0; i <= getBorderFactor(); i++)
		{
			draw_set_color(!isHighlighted ? color_Border : color_Border_Highlighted);
			draw_ellipse(i, i, gui_width - i, gui_height - i, true);
		}
	}
	
	function makeCircle(_scale_radius = .25)
	{
		var ratio;
		
		if (is_undefined(parent))
			ratio = window_get_width() / window_get_height();
		else
			ratio = (window_get_width() *parent.scale_width) / (window_get_height() * parent.scale_height);
		
		scale_width = ratio >= 1 ? _scale_radius / ratio : _scale_radius;
		scale_height = ratio >= 1 ? _scale_radius : _scale_radius * ratio;
	}
}

function Label() : GUI_BaseClass() constructor
{
	text = "label";
	
	color_Text = make_color_rgb(255,255,255);
	color_Text_Highlighted = make_color_rgb(255,255,255);
	
	font = -1;
	text_angle = 0;
	
	scale_text_width = 1;
	scale_text_height = 1;
	
	horizontal_alignment = fa_center;
	vertical_alignment = fa_middle;
	
	background = new Rectangle();
	background.setBothAlpha(0);
	
	function setBothColorText(_color = make_color_rgb(255,255,255))
	{
		color_Text = _color;
		color_Text_Highlighted = _color;
	}
	
	function draw()
	{
		var gui_width = window_get_width();
		var gui_height = window_get_height();
		display_set_gui_maximise(scale_width, scale_height, gui_width *scale_x, gui_height *scale_y);
		
		background.parent = self;
		background.setCenter(1,1);
		background.draw();
		
		var isHighlighted = mouseOver();
		draw_set_alpha(!isHighlighted ? alpha : alpha_highlighted);			
		
		draw_set_font(font);
		draw_set_halign(horizontal_alignment);
		draw_set_valign(vertical_alignment);
		draw_set_color(!isHighlighted ? color_Text : color_Text_Highlighted);

		display_set_gui_size(surface_get_width(application_surface), surface_get_height(application_surface));
		draw_text_transformed(getTextX(surface_get_width(application_surface)), getTextY(surface_get_height(application_surface)), text, scale_text_width, scale_text_height, text_angle);
	}
	
	function scaleText(_factor = 1)
	{
		scale_text_width = _factor;
		scale_text_height = _factor;
	}
	
	var function getTextX(gui_width)
	{
		var text_x = 0;
		
		if (horizontal_alignment == fa_center)
			text_x = gui_width *scale_x + gui_width *scale_width / 2;
		else if (horizontal_alignment == fa_left)
			text_x = gui_width *scale_x;
		else if (horizontal_alignment == fa_right)
			text_x = gui_width *scale_x + gui_width *scale_width;
			
		return text_x;
	}
	
	var function getTextY(gui_height)
	{
		var text_y = 0;
		
		if (vertical_alignment == fa_middle)
			text_y = gui_height *scale_y + gui_height *scale_height / 2;
		else if (vertical_alignment == fa_top)
			text_y = gui_height *scale_y;
		else if (vertical_alignment == fa_bottom)
			text_y = gui_height *scale_y + gui_height *scale_height;
			
		return text_y;
	}
}
